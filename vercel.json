{
  "buildCommand": "npm run build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 512
    }
  },
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/dist/client/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
